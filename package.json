{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs'); for (const file of ['package-lock.json','yarn.lock']) { try { fs.rmSync(file, { force: true }); } catch {} } const ua=process.env.npm_config_user_agent||''; if (!ua.startsWith('pnpm/')) { console.error('Use pnpm instead'); process.exit(1); }\"",
    "dev:edms": "pnpm --filter @workspace/edms run dev",
    "dev:api-server": "pnpm --filter @workspace/api-server run dev",
    "dev:mockup-sandbox": "pnpm --filter @workspace/mockup-sandbox run dev",
    "build": "pnpm run build:fast",
    "build:edms": "pnpm --filter @workspace/edms run build",
    "build:api-server": "pnpm --filter @workspace/api-server run build",
    "build:fast": "pnpm -r --workspace-concurrency=Infinity --filter \"./artifacts/api-server\" --filter \"./artifacts/edms\" --if-present run build",
    "build:strict": "pnpm run typecheck && pnpm run build:fast",
    "typecheck:libs": "tsc --build",
    "typecheck:edms": "pnpm --filter @workspace/edms run typecheck",
    "typecheck:api-server": "pnpm --filter @workspace/api-server run typecheck",
    "typecheck:mockup-sandbox": "pnpm --filter @workspace/mockup-sandbox run typecheck",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "biome format --write .",
    "format:prettier": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,json,md}\" \"artifacts/**/*.{ts,tsx,js,jsx,css,json,md}\" \"lib/**/*.{ts,tsx,js,jsx,css,json,md}\"",
    "lint:frontend": "biome lint .",
    "lint:frontend:prettier": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,json,md}\" \"artifacts/**/*.{ts,tsx,js,jsx,css,json,md}\" \"lib/**/*.{ts,tsx,js,jsx,css,json,md}\"",
    "lint:backend": "python -m ruff check backend",
    "lint": "pnpm run lint:frontend && pnpm run lint:backend",
    "biome:check": "biome check .",
    "biome:fix": "biome check --write ."
  },
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@rollup/rollup-win32-x64-msvc": "4.60.1",
    "@tailwindcss/oxide-win32-x64-msvc": "4.2.2",
    "@vitest/ui": "4.1.2",
    "jsdom": "29.0.1",
    "lightningcss-win32-x64-msvc": "1.32.0",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  },
  "pnpm": {
    "overrides": {
      "lodash": "^4.18.0",
      "picomatch": "^4.0.4",
      "yaml": "^2.8.3",
      "path-to-regexp": "^0.1.12",
      "brace-expansion": "^2.0.3",
      "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz",
      "esbuild": "^0.25.0"
    }
  }
}
